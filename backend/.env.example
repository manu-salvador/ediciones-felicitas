PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
# Admin credentials  (REQUERIDO)
# ──────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=reemplazar_con_clave_segura

# ──────────────────────────────────────────────
# JWT  (REQUERIDO)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────────
JWT_SECRET=reemplazar_con_secreto_largo_y_aleatorio

# ──────────────────────────────────────────────
# URLs  (REQUERIDO en producción)
# ──────────────────────────────────────────────
FRONTEND_URL=https://tudominio.com
BACKEND_URL=https://api.tudominio.com

# ──────────────────────────────────────────────
# MercadoPago  (REQUERIDO)
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
# Usar credenciales TEST para staging, PROD para producción
# ──────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx-xxxx

# Secret del webhook (REQUERIDO en producción)
# Obtener en: MP Dashboard → Tu app → Webhooks → Clave secreta
MP_WEBHOOK_SECRET=reemplazar_con_secret_del_webhook_de_mp

# ──────────────────────────────────────────────
# Base de datos  (REQUERIDO en producción)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ediciones_felicitas

# Poner "false" SOLO si tu proveedor de DB usa cert autofirmado (Railway, Render, etc.)
# En general dejar vacío o "true"
DB_SSL_REJECT_UNAUTHORIZED=true

# ──────────────────────────────────────────────
# Cloudflare R2 — almacenamiento de archivos  (REQUERIDO)
#
# Cómo obtener estos valores:
# 1. Crear cuenta en cloudflare.com
# 2. Ir a R2 → Create bucket → nombre: "ediciones-felicitas"
# 3. En el bucket: Settings → Public Access → habilitar (para portadas)
#    Copiar el dominio público que aparece ahí (R2_PUBLIC_URL)
# 4. Ir a R2 → Manage R2 API tokens → Create API token
#    Permisos: Object Read & Write en el bucket creado
#    Copiar Account ID, Access Key ID y Secret Access Key
# ──────────────────────────────────────────────
R2_ACCOUNT_ID=tu-account-id-de-cloudflare
R2_ACCESS_KEY_ID=tu-access-key-id
R2_SECRET_ACCESS_KEY=tu-secret-access-key
R2_BUCKET_NAME=ediciones-felicitas
# URL pública del bucket (se ve en Settings → Public Access del bucket)
# Formato: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
