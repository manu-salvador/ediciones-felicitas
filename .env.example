# ===========================
# Server
# ===========================
NODE_ENV=development
PORT=3001

# ===========================
# Base de datos
# ===========================
DATABASE_URL=postgresql://user:password@localhost:5432/ediciones_felicitas

# ===========================
# JWT
# ===========================
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro
JWT_EXPIRY=24h

# ===========================
# MercadoPago (Argentina)
# ===========================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ===========================
# Google OAuth 2.0 (admin)
# ===========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/admin/auth/google/callback

# ===========================
# Email transaccional (TBD: Resend o SendGrid)
# ===========================
EMAIL_API_KEY=
EMAIL_FROM=noreply@edicionesfelicitas.com.ar

# ===========================
# Filesystem (Railway Volume)
# ===========================
UPLOADS_PATH=./uploads

# ===========================
# Frontend (Vite)
# ===========================
VITE_API_URL=http://localhost:3001
VITE_MP_PUBLIC_KEY=
